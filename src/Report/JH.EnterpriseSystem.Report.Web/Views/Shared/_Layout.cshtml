<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JH 報表系統</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- 報表自訂樣式 -->
    <link rel="stylesheet" href="~/css/report.css" asp-append-version="true" />
</head>
<body>

    <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">JH 報表系統</a>
        </div>
    </nav>

    <div class="container-fluid">
        @RenderBody()
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Highcharts CDN -->
    <script src="https://cdn.jsdelivr.net/npm/highcharts@11/highcharts.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/highcharts@11/modules/exporting.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/highcharts@11/modules/accessibility.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>